{
  "name": "hjh538",
  "private": true,
  "version": "0.1.0",
  "description": "回合制策略H5网页网游",
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm run dev:server & pnpm run dev:web",
    "build:server": "pnpm --filter server build",
    "build:web": "pnpm --filter web build",
    "build": "pnpm run build:server && pnpm run build:web",
    "prisma:generate": "pnpm --filter server prisma generate",
    "prisma:migrate": "pnpm --filter server prisma migrate dev",
    "prisma:studio": "pnpm --filter server prisma studio",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.5"
  }
}
